{
  "name": "home-device-control",
  "version": "2.1.0",
  "description": "控制小米智能家居设备的原子工具，支持设备查询、控制和场景执行",
  "author": "OpenClaw",
  "license": "MIT",
  "homepage": "https://github.com/ddandre32/HomeDeviceControl",
  "metadata": {
    "openclaw": {
      "emoji": "🏠",
      "requires": {
        "bins": ["home-device"],
        "env": ["MIOT_TOKEN"],
        "config": ["channels.xiaomi.enabled"]
      },
      "primaryEnv": "MIOT_TOKEN",
      "install": [
        {
          "id": "pip",
          "kind": "pip",
          "package": "git+https://github.com/ddandre32/HomeDeviceControl.git",
          "bins": ["home-device"]
        }
      ],
      "complexity": "high"
    }
  },
  "tools": [
    {
      "name": "list_devices",
      "description": "列出所有智能家居设备",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "渠道名称",
            "default": "xiaomi"
          },
          "json": {
            "type": "boolean",
            "description": "JSON 格式输出",
            "default": false
          }
        }
      }
    },
    {
      "name": "control_device",
      "description": "控制设备（原子操作：开关、调节等）",
      "parameters": {
        "type": "object",
        "properties": {
          "device_id": {
            "type": "string",
            "description": "设备ID"
          },
          "action": {
            "type": "string",
            "enum": ["turn_on", "turn_off", "set_brightness", "set_temperature"],
            "description": "动作"
          },
          "value": {
            "type": ["number", "string"],
            "description": "参数值",
            "default": null
          },
          "channel": {
            "type": "string",
            "description": "渠道名称",
            "default": "xiaomi"
          },
          "dry_run": {
            "type": "boolean",
            "description": "预览模式",
            "default": false
          },
          "yes": {
            "type": "boolean",
            "description": "自动确认",
            "default": false
          }
        },
        "required": ["device_id", "action"]
      }
    },
    {
      "name": "list_scenes",
      "description": "列出所有智能场景",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "description": "渠道名称",
            "default": "xiaomi"
          },
          "json": {
            "type": "boolean",
            "description": "JSON 格式输出",
            "default": false
          }
        }
      }
    },
    {
      "name": "execute_scene",
      "description": "执行智能场景",
      "parameters": {
        "type": "object",
        "properties": {
          "scene_id": {
            "type": "string",
            "description": "场景ID"
          },
          "channel": {
            "type": "string",
            "description": "渠道名称",
            "default": "xiaomi"
          },
          "dry_run": {
            "type": "boolean",
            "description": "预览模式",
            "default": false
          },
          "yes": {
            "type": "boolean",
            "description": "自动确认",
            "default": false
          }
        },
        "required": ["scene_id"]
      }
    },
    {
      "name": "check_channels",
      "description": "检查所有渠道状态",
      "parameters": {
        "type": "object",
        "properties": {
          "json": {
            "type": "boolean",
            "description": "JSON 格式输出",
            "default": false
          }
        }
      }
    }
  ],
  "entry": "channels/__init__.py",
  "config": {
    "default_channel": "xiaomi",
    "timeout": 30
  }
}
